{
  "name": "invois-macos",
  "version": "0.1.0",
  "private": true,
  "description": "Invois — local-first invoice generator for macOS (Electron + Next.js).",
  "main": "electron/main.js",
  "author": "Arif Riyanto",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "concurrently -k -n next,electron -c blue,magenta \"next dev\" \"wait-on tcp:3000 && cross-env ELECTRON_DEV=1 electron .\"",
    "dev:next": "next dev",
    "build": "next build",
    "start": "electron .",
    "typecheck": "tsc --noEmit",
    "pdf:fonts": "node scripts/pdf-fonts.mjs",
    "lint": "eslint src",
    "test": "vitest run",
    "pack:mac": "npm run build && electron-builder --mac dir",
    "pack:mas-dev": "npm run build && electron-builder --mac mas-dev",
    "pack:mas": "npm run build && electron-builder --mac mas",
    "size": "du -sh dist/*/Invois.app 2>/dev/null || echo 'nothing built yet — run a pack:* script first'"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "html2canvas": "^1.4.1",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "pdf-lib": "^1.17.1",
    "posthog-js": "^1.396.2",
    "radix-ui": "^1.6.0",
    "react": "19.2.4",
    "react-colorful": "^5.7.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "latest",
    "electron-builder": "latest",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prettier": "^3.9.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.6",
    "wait-on": "^8.0.1"
  }
}
